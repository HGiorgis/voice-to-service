# Django
DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,your-app.onrender.com

# Production (e.g. Render): DEBUG=False, https FRONTEND_URL, and CSRF for your public origin only.
# Render sets RENDER=true — enables SECURE_PROXY_SSL_HEADER so Google OAuth uses https redirect URIs.
# Other TLS proxies: set SECURE_BEHIND_PROXY=1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://your-app.onrender.com

# Public URL used in verification emails (no trailing slash)
FRONTEND_URL=http://localhost:8000

# Email (OTP after password sign-up). Leave EMAIL_HOST_USER empty → console backend (logs only; good for local dev).
#
# Render / PaaS: Gmail SMTP usually fails (network unreachable). Use a transactional relay — see docs/email-smtp-render.md
# Recommended free tier: Brevo (~300 emails/day, SMTP). Example:
#   EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#   EMAIL_HOST=smtp-relay.brevo.com
#   EMAIL_PORT=587
#   EMAIL_USE_TLS=True
#   EMAIL_USE_SSL=False
#   EMAIL_HOST_USER=<SMTP login from Brevo SMTP settings>
#   EMAIL_HOST_PASSWORD=<SMTP key from Brevo (not your Brevo password)>
#   DEFAULT_FROM_EMAIL=<sender verified in Brevo>
# If 587 is blocked, try EMAIL_PORT=2525
#
# SendGrid (example): EMAIL_HOST=smtp.sendgrid.net, EMAIL_HOST_USER=apikey, EMAIL_HOST_PASSWORD=<API key>
# Debug only: EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
# SMTP connect timeout (seconds); avoids long hangs when the host is unreachable (e.g. Docker network).
EMAIL_TIMEOUT=15
DEFAULT_FROM_EMAIL=noreply@voice-to-service.com
# Inbox "From" display name (use with your real noreply/domain address in production)
# DEFAULT_FROM_NAME=Voice To Service
# EMAIL_VERIFICATION_EXPIRE_MINUTES=15
# EMAIL_VERIFICATION_RESEND_SECONDS=60
# EMAIL_VERIFICATION_SEND_MAX=5
# PENDING_SIGNUP_EMAIL_CHANGE_COOLDOWN_SECONDS=120
# UNVERIFIED_SIGNUP_EXPIRE_HOURS=48

DATABASE_URL=sqlite:///db.sqlite3
# Database (PostgreSQL recommended). Leave empty for local SQLite.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Google Cloud — Speech-to-Text + Translation (service account JSON)
# Production / Render: use Base64 only — do not paste raw JSON into GOOGLE_APPLICATION_CREDENTIALS.
#   python scripts/encode_gcp_credentials_b64.py key/your-key.json
# Then in Render: set GOOGLE_APPLICATION_CREDENTIALS_B64=<output>; leave GOOGLE_APPLICATION_CREDENTIALS unset (or a real file path locally).
# GOOGLE_APPLICATION_CREDENTIALS_B64=
# Local dev: file path to JSON (not the JSON string itself)
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/voice-to-service-account.json
# Required for Speech-to-Text v2; also in service account JSON as project_id.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# v2 recognizer location (matches Console batch): global + model long + am-ET
GOOGLE_CLOUD_STT_V2_LOCATION=global
# Optional: model(s). At location global, default is long only (Chirp is not on global).
GOOGLE_CLOUD_STT_V2_MODEL=long
GOOGLE_CLOUD_STT_V2_MODELS=long,chirp_2

# Google OAuth — “Continue with Google” on /auth/login/ and /auth/register/
# Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client (Web).
# Authorized redirect URIs must match EXACTLY (scheme, host, path, trailing slash):
#   http://127.0.0.1:8000/oauth/complete/google-oauth2/
#   https://YOUR-SERVICE.onrender.com/oauth/complete/google-oauth2/
# Use https for production. If you see redirect_uri_mismatch, add both Console URI + SECURE_PROXY_SSL (RENDER=true).
GOOGLE_OAUTH2_CLIENT_ID=
GOOGLE_OAUTH2_CLIENT_SECRET=

# Google Gemini — intent classification (temporary; replace with your ML model later)
GEMINI_API_KEY=your-gemini-api-key
# Optional model override (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Optional: Backblaze B2 / S3-compatible private storage for uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=

# Default admin (management command)
DEFAULT_ADMIN_PASSWORD=secure-password-here
DEFAULT_ADMIN_EMAIL=admin@example.com
